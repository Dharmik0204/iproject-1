<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Initialize structural animations tracking layout
        AOS.init({ once: true, mirror: false });

        // 🚀 ADVANCED RADIAL CIRCLE FILL ROTATION SYSTEM ENGINE
        function triggerRadialAnimations() {
            const nodes = document.querySelectorAll('.radial-progress-node');
            const circumference = 440; // Total stroke loop circumference context based on $2\pi r$ ($2 \times 3.14 \times 70$)

            nodes.forEach(node => {
                const percent = parseInt(node.getAttribute('data-percentage'));
                const circle = node.querySelector('.fill-dash');

                if (circle) {
                    // Set circle line to fully empty before triggering loading trace path
                    circle.style.strokeDashoffset = circumference;

                    // Force the browser layout engine engine to draw fresh frames
                    requestAnimationFrame(() => {
                        setTimeout(() => {
                            const offset = circumference - (percent / 100) * circumference;
                            circle.style.strokeDashoffset = offset;
                            node.classList.add('animated-run'); // Triggers text opacity transition smoothly
                        }, 100);
                    });
                }
            });
        }

        // Safe anchor fallback execution depending on loading states
        if (document.readyState === "complete" || document.readyState === "interactive") {
            setTimeout(triggerRadialAnimations, 400);
        } else {
            window.addEventListener('load', () => setTimeout(triggerRadialAnimations, 400));
        }
    });
</script>