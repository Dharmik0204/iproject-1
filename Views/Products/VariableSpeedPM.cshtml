    /* 📊 DYNAMIC RADIAL CIRCLE ROTATION & ANIMATION INTERFACE */
    .circle-matrix-box {
        background: #0b1224;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 40px 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    }

    .radial-progress-node {
        position: relative;
        width: 160px;
        height: 160px;
        margin: 0 auto 25px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .radial-progress-node svg {
            position: absolute;
            width: 100%;
            height: 100%;
            transform: rotate(-90deg); /* Starts the circle drawing pattern cleanly from top center */
        }

        .radial-progress-node circle {
            cx: 80;
            cy: 80;
            r: 70;
            fill: none;
            stroke-width: 12;
            stroke-linecap: round;
        }

            .radial-progress-node circle.track-bg {
                stroke: #1e293b;
            }

            .radial-progress-node circle.fill-dash {
                stroke: #00d4ff; /* Process Cyan High Contrast Highlight Theme Color */
                stroke-dasharray: 440; /* Full loop circumference bounds */
                stroke-dashoffset: 440; /* Start empty to prepare for loading path */
                transition: stroke-dashoffset 2.5s cubic-bezier(0.1, 1, 0.1, 1); /* Premium smooth ease-out rotation speed */
            }

    .percentage-display {
        font-family: 'Montserrat', sans-serif;
        font-size: 2rem;
