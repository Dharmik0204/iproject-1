<style>
    /* 🚀 PREMIUM MATRIX INDUSTRIAL THEME */
    .aerodyne-details-engine {
        font-family: 'Open Sans', sans-serif;
        color: #ffffff;
        background-color: #0f172a; /* Slate Black Backdrop */
        overflow-x: hidden;
    }

        .aerodyne-details-engine h1,
        .aerodyne-details-engine h2,
        .aerodyne-details-engine h3,
        .aerodyne-details-engine h4,
        .aerodyne-details-engine h5,
        .aerodyne-details-engine h6 {
            font-family: 'Montserrat', sans-serif;
        }

    /* Hero Sub-header banner */
    .detail-hero {
        background: linear-gradient(135deg, #091224 0%, #002244 100%);
        border-bottom: 3px solid #004aad;
        padding: 60px 0;
        position: relative;
    }

    .back-btn {
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.8rem;
    }

        .back-btn:hover {
            background-color: #004aad !important;
            color: white !important;
            transform: translateX(-5px);
        }

    /* 🛡️ EXCEPTIONAL VALUES - STRIP DISPLAY FOR 4 IMAGES */
    .value-matrix-box {
        background: #0b1224;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 40px 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    }

    .industrial-strip-grid {
        display: flex;
        gap: 15px;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .feature-strip-card {
        flex: 1;
        min-width: 140px;
        background: #0b1224;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .feature-strip-card:hover {
            transform: translateY(-5px);
        }

    /* Exact Flyer Layout Aspect Ratio Box */
    .strip-img-box {
        width: 100%;
        height: 220px; /* Enhanced height scale to give clear visibility to core machine parts */
        overflow: hidden;
        border: 2px solid rgba(0, 212, 255, 0.2); /* Subtle blueprint cyan border around the strips */
        border-bottom: none;
        border-radius: 4px 4px 0 0;
    }

        .strip-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .feature-strip-card:hover .strip-img-box img {
        transform: scale(1.08);
    }

    /* Header text line (e.g., 2-stage, High Quality) */
    .strip-primary-text {
        width: 100%;
        text-align: center;
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        color: #ffffff;
        padding: 10px 4px 4px 4px;
        background: transparent;
    }

    /* Footer label block matching white box in image flyer */
    .strip-footer-label {
        width: 100%;
        text-align: center;
        background: #ffffff;
        color: #00337c;
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 0.65rem;
        letter-spacing: 0.5px;
        padding: 6px 2px;
        text-transform: uppercase;
        border-radius: 0 0 4px 4px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    /* 📋 HIGHLY DETAILED TECHNICAL PARAMETERS TABLE */
    .spec-table-container {
        background: #0b1224;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .premium-spec-table {
        width: 100%;
        color: #ffffff;
        border-collapse: collapse;
        font-size: 0.9rem;
    }

        .premium-spec-table th {
            background: #00337c !important;
            color: #ffffff !important;
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            padding: 12px 6px;
            border: 1px solid #1e293b !important;
            text-align: center;
            vertical-align: middle;
        }

        .premium-spec-table td {
            padding: 8px 6px;
            border: 1px solid #1e293b;
            text-align: center;
            vertical-align: middle;
            background: #0b1224;
            transition: background 0.2s ease;
        }

        .premium-spec-table tbody tr:hover td {
            background: #152244 !important;
        }

    .model-highlight {
        font-weight: 700;
        color: #00d4ff;
        text-align: left !important;
        padding-left: 15px !important;
    }

    /* HIGH LEGIBILITY SUMMARY CORES */
    .high-contrast-summary {
        color: #ffffff !important; /* Fixed: Changed from dull grey to 100% crisp pure white text */
        font-size: 0.98rem;
        line-height: 1.75;
        text-align: justify;
    }

    .high-contrast-footer {
        color: #ffffff !important; /* Fixed: Footer credentials are now bright white for supreme visibility */
        font-size: 0.85rem;
    }
</style>

