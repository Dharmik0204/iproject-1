
@model AerodyneCompressors.Models.ContactFormModel

@{
    ViewData["Title"] = "Contact AERODYNE EQUIPMENTS | Air Compressor Factory Ahmedabad";
    ViewData["MetaDescription"] = "Get in touch alongside AERODYNE EQUIPMENTS engineering team for certified free fleet proposals, corporate industrial energy audits, and industrial air system optimization support.";
    ViewData["MetaKeywords"] = "contact aerodyne compressors, air compressor factory ahmedabad, request compressor proposal, book energy audit india, air engineering support desk";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

<style>
    /* 🚀 PREMIUM CHARCOAL LIGHT BLACK BASE SCHEME */
    .contact-page-engine {
        font-family: 'Open Sans', sans-serif;
        color: #ffffff;
        background-color: #0f172a; /* Light Charcoal Black Background Theme */
        overflow-x: hidden;
    }

        .contact-page-engine h1,
        .contact-page-engine h2,
        .contact-page-engine h3,
        .contact-page-engine h4,
        .contact-page-engine h5,
        .contact-page-engine h6 {
            font-family: 'Montserrat', sans-serif;
        }

    .contact-header {
        background-color: #0b1224;
        padding: 85px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        margin-bottom: 60px;
    }

    /* 2. Premium 3D Interactive Layout Form Card */
    .contact-card {
        border: 1px solid rgba(0, 74, 173, 0.25);
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
        border-radius: 16px;
        background-color: #0b1224; /* Deep matte black inner block card */
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        transform: perspective(1000px);
    }

        .contact-card:hover {
            transform: translateY(-5px) rotateX(1deg); /* Subtle Dynamic 3D Lift */
            border-color: #00d4ff;
            box-shadow: 0 30px 60px rgba(0, 74, 173, 0.35);
        }

    .form-group-wrapper {
        margin-bottom: 22px; /* Fixed spacing layer to guarantee error messages never overflow blocks */
        position: relative;
    }

    .form-floating > .form-control {
        background-color: #0f172a !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #ffffff !important;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .form-floating > label {
        color: rgba(255, 255, 255, 0.6) !important;
    }

    .form-floating > .form-control:focus {
        border-color: #00d4ff !important;
        box-shadow: 0 0 0 0.25rem rgba(0, 212, 255, 0.2) !important;
    }

    /* 🚀 RE-INTEGRATED SHARP HIGHLIGHTED VALIDATION ERRORS */
    .field-validation-error {
        color: #ef5350 !important; /* Premium industrial soft red alert text */
        font-size: 0.82rem;
        font-weight: 600;
        display: block;
        margin-top: 6px;
        padding-left: 4px;
        letter-spacing: 0.3px;
        text-align: left;
    }

    /* 🚀 HIGH-STAKES CORPORATE BLUE BUTTON GRAPHICS */
    .btn-submit {
        background-color: #004aad !important; /* Brand Corporate Blue */
        color: white !important;
        padding: 14px 30px;
        font-weight: 700;
        border-radius: 4px;
        border: 2px solid transparent;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .btn-submit:hover {
            background-color: transparent !important;
            border-color: #00d4ff !important;
            color: #00d4ff !important;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(0, 74, 173, 0.35);
        }

    /* 3. Direct Contact Panels with Micro 3D Scale Interactivity */
    .info-panel-box {
        background: #0b1224;
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 12px;
        padding: 24px;
        transition: all 0.35s ease;
    }

        .info-panel-box:hover {
            border-color: rgba(0, 74, 173, 0.4);
            transform: translateX(6px);
            background: #1e293b;
        }

    .contact-info-item i {
        font-size: 1.7rem;
        color: #00d4ff; /* Radiant Electric Cyan Icon */
        margin-right: 20px;
    }

    .contact-info-item p {
        color: #cbd5e1;
        line-height: 1.6;
        margin-bottom: 0;
    }

    /* Business Hours Container Matrix */
    .hours-badge-panel {
        background-color: #0b1224;
        border: 1px solid rgba(0, 74, 173, 0.2);
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        border-radius: 12px;
        transition: all 0.35s ease;
    }

        .hours-badge-panel:hover {
            border-color: #00d4ff;
            transform: translateY(-3px);
        }

    .section-pill-tag {
        background-color: rgba(0, 74, 173, 0.2);
        color: #00d4ff;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: inline-block;
        margin-bottom: 15px;
    }

    /* 🚀 RE-DESIGNED BRAND METALLIC GREEN ALERT SUCCESS SUITE */
    .alert-premium-success {
        background-color: rgba(16, 185, 129, 0.1) !important;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        color: #10b981 !important;
        font-weight: 600;
        border-radius: 8px;
        padding: 16px 20px;
        letter-spacing: 0.3px;
    }

    @@media (max-width: 992px) {
        .contact-header {
            padding: 60px 0;
            margin-bottom: 40px;
        }

        .contact-card {
            padding: 35px 20px !important;
        }

        .info-panel-box:hover {
            transform: translateY(-3px);
        }
    }
</style>

<div class="contact-page-engine">

    <div class="contact-header text-center">
        <div class="container" data-aos="zoom-in" data-aos-duration="800">
            <span class="section-pill-tag">Connect Hub</span>
            <h1 class="display-5 fw-bold mb-3" style="color: #00d4ff;">Get In Touch Along Our Support Desk</h1>
            <p class="lead mx-auto text-white-50" style="max-width: 800px; font-size: 1.1rem; line-height: 1.75;">
                If you are ready to take the first technical milestone toward a highly automated and power-optimized factory system, connect with AERODYNE's engineering helpdesk today.
            </p>
        </div>
    </div>

    <div class="container mb-5 pb-5">
        <div class="row g-5">

            <div class="col-lg-7" data-aos="fade-right" data-aos-duration="1000">
                <div class="card contact-card p-4 p-md-5">
                    <h3 class="mb-4 fw-bold text-white">Send us a Message</h3>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-premium-success d-flex align-items-center mb-4 shadow-sm fade show" role="alert">
                            <i class="bi bi-check-circle-fill fs-5 me-3"></i>
                            <div>@TempData["SuccessMessage"]</div>
                        </div>
                    }

                    <form asp-action="ContactUs" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 d-flex flex-column form-group-wrapper">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                    <label asp-for="Name"></label>
                                </div>
                                <span asp-validation-for="Name"></span>
                            </div>
                            <div class="col-md-6 d-flex flex-column form-group-wrapper">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" placeholder="Email Address" />
                                    <label asp-for="Email"></label>
                                </div>
                                <span asp-validation-for="Email"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 d-flex flex-column form-group-wrapper">
                                <div class="form-floating">
                                    <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                                    <label asp-for="Phone"></label>
                                </div>
                                <span asp-validation-for="Phone"></span>
                            </div>
                            <div class="col-md-6 d-flex flex-column form-group-wrapper">
                                <div class="form-floating">
                                    <input asp-for="Company" class="form-control" placeholder="Company Name" />
                                    <label asp-for="Company">Company (Optional)</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column form-group-wrapper">
                            <div class="form-floating">
                                <input asp-for="Subject" class="form-control" placeholder="Subject" />
                                <label asp-for="Subject"></label>
                            </div>
                            <span asp-validation-for="Subject"></span>
                        </div>

                        <div class="d-flex flex-column form-group-wrapper" style="margin-bottom: 30px;">
                            <div class="form-floating">
                                <textarea asp-for="Question" class="form-control" placeholder="Leave a message here" style="height: 150px"></textarea>
                                <label asp-for="Question">Your Question / Message</label>
                            </div>
                            <span asp-validation-for="Question"></span>
                        </div>

                        <button type="submit" class="btn btn-submit w-100 shadow">SUBMIT TECHNICAL ENQUIRY</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-5" data-aos="fade-left" data-aos-duration="1000">
                <h3 class="fw-bold mb-4 text-white">Direct Engineering Contact</h3>

                <div class="space-y-wrapper d-flex flex-column gap-4">

                    <div class="info-panel-box contact-info-item d-flex align-items-center">
                        <div><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h4 class="fw-bold text-white mb-1" style="font-size: 1.05rem;">Corporate Headquarters Factory</h4>
                            <p>82, Gajanan Ind. Estate -3, Kathwada-Singarva Rd, Ahmedabad, Gujarat-382430</p>
                        </div>
                    </div>

                    <div class="info-panel-box contact-info-item d-flex align-items-center">
                        <div><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h4 class="fw-bold text-white mb-1" style="font-size: 1.05rem;">Direct Procurement Line</h4>
                            <p class="text-white fw-bold" style="font-size: 1.05rem;">+91 63523-86643</p>
                        </div>
                    </div>

                    <div class="info-panel-box contact-info-item d-flex align-items-center">
                        <div><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h4 class="fw-bold text-white mb-1" style="font-size: 1.05rem;">Corporate Support Desk</h4>
                            <p>aerodyne.equipments@gmail.com</p>
                        </div>
                    </div>

                </div>

                <div class="hours-badge-panel p-4 mt-4">
                    <h5 class="fw-bold text-white mb-3" style="font-size: 1rem;"><i class="bi bi-clock-history me-2" style="color: #00d4ff;"></i>Business Hours Matrix</h5>
                    <hr style="background-color: rgba(255,255,255,0.15);" />
                    <div class="d-flex justify-content-between small mb-2 opacity-90">
                        <span>Monday - Saturday:</span>
                        <span class="fw-bold text-white">10:00 AM - 6:00 PM</span>
                    </div>
                    <div class="d-flex justify-content-between small opacity-90">
                        <span>Sunday Industrial Holiday:</span>
                        <span class="text-danger fw-bold">Closed</span>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        AOS.init({
            once: true,
            mirror: false
        });
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


