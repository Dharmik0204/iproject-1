
@model AerodyneCompressors.Models.ContactFormModel

@{
    ViewData["Title"] = "Customized OEM Compressed Air Solutions & Fleet Design | AERODYNE";
    ViewData["MetaDescription"] = "Partner alongside AERODYNE EQUIPMENTS for specialized industrial OEM air systems. We offer custom structural product design, bulk inventory cost optimization, and factor-verified engineering solutions.";
    ViewData["MetaKeywords"] = "oem air compressor solutions, custom compressor design factory, industrial component fabrication ahmedabad, specialized compressor engineering, aerodyne mechanical solutions";
}

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

<style>
    /* 🚀 PREMIUM CHARCOAL DARK INDUSTRIAL PLATFORM CONTEXT */
    .oem-page-engine {
        font-family: 'Open Sans', sans-serif;
        color: #ffffff;
        background-color: #0f172a; /* Smooth Corporate Dark Base Backdrop */
        overflow-x: hidden;
    }

        .oem-page-engine h1,
        .oem-page-engine h2,
        .oem-page-engine h3,
        .oem-page-engine h4,
        .oem-page-engine h5,
        .oem-page-engine h6 {
            font-family: 'Montserrat', sans-serif;
        }

    /* 1. Immersive Layered Parallax Hero Space */
    .oem-hero {
        background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.95)), url('@Url.Content("~/images/home4.webp")');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Parallax 3D Engine Tracking */
        color: white;
        padding: 140px 0;
        text-align: center;
        border-radius: 0 0 50px 50px;
        box-shadow: 0 25px 50px rgba(0, 74, 173, 0.3);
        border-bottom: 4px solid #004aad;
    }

    .oem-intro-text {
        max-width: 950px;
        margin: 60px auto;
        font-size: 1.15rem;
        line-height: 1.9;
        color: #cbd5e1; /* Pure Legible Contrast Matte White Description */
        text-align: justify;
    }

    /* 2. Symmetrical Alternating Blocks Framework */
    .oem-section {
        padding: 110px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

        .oem-section:nth-child(even) {
            background-color: #0b1224; /* Seamless deep dark matte block arrays */
        }

    .oem-title {
        font-weight: 800;
        font-size: 2.8rem;
        margin-bottom: 25px;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .oem-title span {
            color: #00d4ff; /* Radiant Electric Neon Cyan color focus nodes */
            display: block;
            font-size: 1.9rem;
            margin-top: 6px;
            font-weight: 600;
        }

    .oem-description {
        font-size: 1.05rem;
        line-height: 1.85;
        color: #e2e8f0;
        margin-bottom: 35px;
    }

    /* 🚀 TACTICAL BRAND JOURNEY LINK TRIGGERS */
    .btn-journey {
        background-color: #004aad !important; /* Fixed corporate blue accent */
        color: #ffffff !important;
        border: 2px solid transparent;
        padding: 14px 35px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        box-shadow: 0 4px 15px rgba(0, 74, 173, 0.2);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: inline-block;
        text-decoration: none;
    }

        .btn-journey:hover {
            background-color: transparent !important;
            color: #00d4ff !important;
            border-color: #00d4ff !important;
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(0, 212, 255, 0.25);
        }

    /* 🚀 ENFORCED 3D ELEVATIONAL IMAGE WRAPPERS OVERLAY */
    .oem-img-container {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.55);
        border: 1px solid rgba(0, 74, 173, 0.3); /* Blueprint core border bounding line */
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        background: #000000;
        position: relative;
    }

        .oem-img-container img {
            width: 100% !important;
            height: 390px; /* Rigidly uniform display limits matching all viewpoints */
            object-fit: cover !important; /* Protects from stretching distortions */
            display: block;
            transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* Interactive 3D Perspective Scale Layer Focus rules */
        .oem-img-container:hover {
            transform: translateY(-10px) rotateX(2deg) rotateY(-1deg); /* Mechanical 3D Tilt Matrix */
            border-color: #00d4ff;
            box-shadow: 0 30px 65px rgba(0, 74, 173, 0.45);
        }

            .oem-img-container:hover img {
                transform: scale(1.06); /* Seamless visual expansion tracking */
            }

    .section-pill-tag {
        background-color: rgba(0, 74, 173, 0.2);
        color: #00d4ff;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: inline-block;
        margin-bottom: 20px;
    }

    /* High Contrast Split Dock CTA Block Terminal */
    .oem-terminal-cta {
        background-color: #000000 !important; /* Pure split solid jet-black framework space */
        padding: 100px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    @@media (max-width: 992px) {
        .oem-hero {
            padding: 100px 0;
            border-radius: 0 0 30px 30px;
        }

        .oem-title {
            font-size: 2.1rem;
        }

            .oem-title span {
                font-size: 1.5rem;
            }

        .oem-img-container {
            margin-bottom: 40px;
        }

            .oem-img-container img {
                height: 300px;
            }
    }
</style>

<div class="oem-page-engine">

    <section class="oem-hero">
        <div class="container" data-instructive-anim="zoom-in" data-aos="zoom-in" data-aos-duration="1000">
            <h1 class="display-3 fw-bold m-0" style="line-height: 1.25;">Strategic Partnership for OEM<br />Specialized Compressed Air Solutions</h1>
        </div>
    </section>

    <div class="container text-center mb-5">
        <div class="oem-intro-text" data-aos="fade-up" data-aos-duration="900" data-aos-delay="100">
            Your long-term industrial success is our absolute commitment. We foster an intimate, transparent collaborative partnership alongside our corporate OEM clients, maintaining open engineering channels to cross-examine evolving workspace requests and troubleshoot execution bottlenecks promptly. Together, we structure a high-durability foundation optimized for mutual asset growth. Our <strong>extensive engineering portfolio</strong> is fine-tuned to target highly specific ambient specifications, and backed with our <strong>deep mechanical application know-how</strong>, we ensure a perfect customized fitment for your facility. Our certified quality control protocols exceed generic market norms, providing factory-tested, reliable, and high-purity air networks that preserve the stellar reputation of your corporate brand layout.
        </div>
    </div>

    <section class="oem-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6" data-aos="fade-right" data-aos-duration="1100">
                    <div class="oem-img-container shadow">
                        <img src="~/images/CostImage.jpg" alt="AERODYNE Customized OEM Cost Optimization and Procurement Analytics Review" />
                    </div>
                </div>
                <div class="col-lg-6 ps-lg-5" data-aos="fade-left" data-aos-duration="1100">
                    <span class="section-pill-tag">Financial Supply Optimization</span>
                    <h2 class="oem-title">Streamlined <span>Cost Efficiency</span></h2>
                    <p class="oem-description" style="text-align: justify;">
                        We systematically prioritize **cost-effective industrial configurations** without compromising precision structural tolerances. Through bulk raw material procurement, optimized automated machinery pipelines, and strategic batch planning, we ensure your bespoke compressor investments deliver rapid, high-margin utility yields. Enjoy absolute peace of mind with our permanent **ex-stock availability** on high-wear components, eliminating expensive inventory overhead costs and unexpected downtime delays from day one.
                    </p>
                    <a href="/Home/ContactUs" class="btn-journey">Request Fleet Allocation Quote</a>
                </div>
            </div>
        </div>
    </section>

    <section class="oem-section">
        <div class="container">
            <div class="row align-items-center g-5 flex-lg-row-reverse">
                <div class="col-lg-6" data-aos="fade-left" data-aos-duration="1100">
                    <div class="oem-img-container shadow">
                        <img src="~/images/Gemini_Generated_Image_74tg6774tg6774tg.png" alt="AERODYNE Advanced Technical Product Design and Component Blueprint Modeling" />
                    </div>
                </div>
                <div class="col-lg-6 pe-lg-5" data-aos="fade-right" data-aos-duration="1100">
                    <span class="section-pill-tag">Custom Machinery Fabrication</span>
                    <h2 class="oem-title">Bespoke Product <span>Engineering Design</span></h2>
                    <p class="oem-description" style="text-align: justify;">
                        Our core technical division collaborates closely alongside industrial buyers to draft precise mechanical system configurations that fit perfectly into pre-existing plant setups. From early CAD blueprint schematics to rigorous factory full-load test evaluations, we ensure every custom compressor array, motor coupling block, and air receiver vessel matches the unique baseline vision and ambient constraints of your business.
                    </p>
                    <a href="/Home/ContactUs" class="btn-journey">Consult a Design Engineer</a>
                </div>
            </div>
        </div>
    </section>

    <section class="oem-terminal-cta text-center" data-aos="zoom-out" data-aos-duration="1000">
        <div class="container py-4">
            <h3 class="fw-bold text-white mb-4" style="font-size: clamp(1.6rem, 3vw, 2.3rem); line-height: 1.3;">Need a Specialized Compressed Air System Built for Your Plant?</h3>
            <p class="mb-5 text-white-50" style="font-size: 1.1rem; max-width: 800px; margin-left: auto; margin-right: auto;">Partner directly alongside AERODYNE's specialized application engineering team to eliminate energy drops and draft a highly competitive fleet proposal.</p>
            <a asp-controller="Home" asp-action="ContactUs" class="btn btn-lg px-5 py-3 fw-bold text-white shadow" style="background-color: #004aad; border: 2px solid #00d4ff; border-radius: 4px; font-size: 0.95rem; letter-spacing: 0.5px;">Acquire Commercial Proposal</a>
        </div>
    </section>

</div>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        AOS.init({
            once: true,
            mirror: false
        });
    });
</script>