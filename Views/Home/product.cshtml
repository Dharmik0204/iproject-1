<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 🎯 FIX 6: Loop execution set to trigger indefinitely on scroll viewport triggers
        AOS.init({ once: false, mirror: true, duration: 900 });

        const layoutInput = document.querySelector('.header-search input');
        if(layoutInput) {
            layoutInput.addEventListener('input', function(e) {
                const searchVal = e.target.value.toLowerCase().trim();
                const items = document.querySelectorAll('.product-search-node');

                items.forEach(function(item) {
                    const keys = item.getAttribute('data-search-keys');
                    if(keys.includes(searchVal)) {
                        item.style.display = "block";
                    } else {
                        item.style.display = "none";
                    }
                });
            });
        }
    });
</script>