        user-select: auto !important;
        opacity: 1 !important;
    }

    .form-group-node {
        margin-bottom: 25px;
    }

    .calc-label {
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        color: #cbd5e1;
        text-transform: uppercase;
        letter-spacing: 0.5px;
