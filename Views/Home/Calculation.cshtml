<div class="aerodyne-calc-engine">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-xl-12" data-aos="fade-up">

                <!-- 🎯 FULL WIDESCREEN REBUILT INDUSTRIAL ACCENT HERO PANEL (Fixed edge boundaries constraints) -->
                <div class="vsd-banner-panel">
                    <div class="container">
                        <div class="row">
                            <div class="col-xl-10 mx-auto">
                                <h2 class="vsd-banner-title">Calculate your VSD savings</h2>
                                <p class="vsd-banner-desc">Calculate your savings on your own, or contact one of our experts to assist in the process</p>
                                <div class="d-flex align-items-center flex-wrap gap-4">
                                    <a href="tel:+916352386643" class="btn-banner-expert">Contact an expert</a>
                                    <a href="@Url.Action("VariableSpeedPM", "Products")" class="link-banner-discover">
                                        Discover our VSD compressors <i class="bi bi-chevron-right small ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 🎯 MASSIVE ENHANCED BOLD TAGLINE SUBTITLE BLOCK -->
                <div class="text-center mb-5 py-3" data-aos="zoom-in">
                    <h3 class="giant-motto-title">
                        "THE VSD SHOWS YOU THE MONEY!"
                    </h3>
                </div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger border-0 text-white mb-4 rounded-3 fw-bold" style="background: #ef5350;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                <!-- Main Calculator Framework Sheet Layer Area -->
                <div class="calculator-card mt-2">
                    <div class="row g-4">

                        <!-- Left Inputs Columns Parameters configuration specs -->
                        <div class="col-md-6">
                            <div class="form-group-node">
                                <label class="calc-label" for="hp">Motor Power (HP Specs)</label>
                                <select id="hp" class="calc-select">
                                    <option value="10" selected="@(TempData["SavedHp"]?.ToString() == "10")">10 HP</option>
                                    <option value="15" selected="@(TempData["SavedHp"]?.ToString() == "15")">15 HP</option>
                                    <option value="20" selected="@(TempData["SavedHp"]?.ToString() == "20")">20 HP</option>
                                    <option value="30" selected="@(TempData["SavedHp"]?.ToString() == "30" || !isUnlocked)">30 HP</option>
                                    <option value="40" selected="@(TempData["SavedHp"]?.ToString() == "40")">40 HP</option>
                                    <option value="50" selected="@(TempData["SavedHp"]?.ToString() == "50")">50 HP</option>
                                    <option value="60" selected="@(TempData["SavedHp"]?.ToString() == "60")">60 HP</option>
                                    <option value="75" selected="@(TempData["SavedHp"]?.ToString() == "75")">75 HP</option>
                                </select>
                            </div>

                            <div class="form-group-node">
                                <label class="calc-label" for="rate">Electricity Cost (Grid Unit ₹/kWh)</label>
                                <input type="range" min="5" max="15" value="@(TempData["SavedRate"] != null ? TempData["SavedRate"] : "8")" id="rate">
                                <div class="slider-value-display">₹ <span id="rateValue">@(TempData["SavedRate"] != null ? TempData["SavedRate"] : "8")</span> / kWh</div>
                            </div>

                            <div class="form-group-node">
                                <label class="calc-label" for="hours">Yearly Running Duty Hours</label>
                                <select id="hours" class="calc-select">
                                    <option value="1000" selected="@(TempData["SavedHours"]?.ToString() == "1000")">1000 Hours</option>
                                    <option value="2000" selected="@(TempData["SavedHours"]?.ToString() == "2000")">2000 Hours</option>
                                    <option value="3000" selected="@(TempData["SavedHours"]?.ToString() == "3000")">3000 Hours</option>
                                    <option value="4000" selected="@(TempData["SavedHours"]?.ToString() == "4000" || !isUnlocked)">4000 Hours</option>
                                    <option value="5000" selected="@(TempData["SavedHours"]?.ToString() == "5000")">5000 Hours</option>
                                    <option value="6000" selected="@(TempData["SavedHours"]?.ToString() == "6000")">6000 Hours</option>
                                    <option value="7000" selected="@(TempData["SavedHours"]?.ToString() == "7000")">7000 Hours</option>
                                    <option value="8000" selected="@(TempData["SavedHours"]?.ToString() == "8000")">8000 Hours</option>
                                </select>
                            </div>
                        </div>

                        <!-- Right Inputs Columns Parameters configuration specs -->
                        <div class="col-md-6">
                            <div class="form-group-node">
                                <label class="calc-label">Air Demand Profile Parameters</label>
                                <div class="radio-card-group">
                                    <label class="radio-custom-label" id="lblDemandStable">
                                        <input type="radio" name="demand" value="stable" checked="@(TempData["SavedDemand"]?.ToString() == "stable")"> Stable Demand
                                    </label>
                                    <label class="radio-custom-label" id="lblDemandFluct">
                                        <input type="radio" name="demand" value="fluctuating" checked="@(TempData["SavedDemand"]?.ToString() == "fluctuating" || !isUnlocked)"> Fluctuating Demand
                                    </label>
                                </div>
                            </div>

                            <div class="form-group-node">
                                <label class="calc-label">Current Plant Technology Status</label>
                                <div class="radio-card-group">
                                    <label class="radio-custom-label" id="lblTechFixed">
                                        <input type="radio" name="tech" value="fixed" checked="@(TempData["SavedTech"]?.ToString() == "fixed" || !isUnlocked)"> Fixed Speed
                                    </label>
                                    <label class="radio-custom-label" id="lblTechVfd">
                                        <input type="radio" name="tech" value="vfd" checked="@(TempData["SavedTech"]?.ToString() == "vfd")"> VSD Technology
                                    </label>
                                </div>
                            </div>

                            <!-- DISPLAY PANEL TARGET (Locked with blur until user fills credentials layout postback) -->
                            <div class="savings-display-panel mt-4">

                                @if (!isUnlocked)
                                {
                                    <div class="panel-gate-overlay" id="inlineGateLock">
                                        <h5 class="fw-bold text-white small text-uppercase tracking-wider mb-2" style="font-size:0.85rem; letter-spacing:0.5px;">TO VIEW TOTAL MORE YOUR SAVINGS</h5>
                                        <form id="gateSubmitForm" asp-action="Calculation" method="post" class="w-100 px-2">
                                            <input type="hidden" name="motorHp" id="formHiddenHp" value="30">
                                            <input type="hidden" name="electricityRate" id="formHiddenRate" value="8">
                                            <input type="hidden" name="runningHours" id="formHiddenHours" value="4000">
                                            <input type="hidden" name="demandProfile" id="formHiddenDemand" value="fluctuating">
                                            <input type="hidden" name="techStatus" id="formHiddenTech" value="fixed">

                                            <div class="row g-2">
                                                <div class="col-sm-6">
                                                    <input type="email" name="clientEmail" class="form-control calc-input-text py-1 px-2" placeholder="Corporate Email Address" required style="font-size:0.8rem; background:#0f172a;">
                                                </div>
                                                <div class="col-sm-6">
                                                    <input type="tel" name="clientPhone" class="form-control calc-input-text py-1 px-2" placeholder="Mobile / WhatsApp" required style="font-size:0.8rem; background:#0f172a;">
                                                </div>
                                            </div>
                                            <button type="submit" class="btn-panel-unlock w-100">Unlock Energy Profile Matrix</button>
                                        </form>
                                    </div>
                                }

                                <div class="@(isUnlocked ? "" : "savings-blur-active")">
                                    <h4 class="fw-bold text-white text-uppercase mb-1" style="font-size:0.85rem; letter-spacing:1px; color:#cbd5e1 !important;">Estimated Annual Electricity Savings</h4>
                                    <div class="savings-counter" id="savings">@savingsOutput</div>
                                    <span class="badge bg-success rounded-1 px-3 py-2 text-uppercase fw-bold" style="font-size:0.7rem; letter-spacing:0.5px;">Power optimization matching up to 45%</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="d-flex justify-content-between flex-wrap gap-3 px-2 text-white small mt-4" style="opacity:0.75;">
                    <div><i class="bi bi-info-circle me-1"></i> Calculations configured based on *kW = HP × 0.746 × 45%* high-efficiency induction systems equations.</div>
                    <div>AERODYNE Corporate Core Line.</div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        AOS.init({ once: false, mirror: true, duration: 900 });

        const rate = document.getElementById("rate");
        const rateValue = document.getElementById("rateValue");
        const gateForm = document.getElementById("gateSubmitForm");

        rate.addEventListener("input", () => {
            rateValue.innerText = rate.value;
            calculate();
        });

        document.querySelectorAll("input, select").forEach(el => {
            el.addEventListener("change", calculate);
        });

        if(gateForm) {
            gateForm.addEventListener("submit", function() {
                document.getElementById("formHiddenHp").value = document.getElementById("hp").value;
                document.getElementById("formHiddenRate").value = rate.value;
                document.getElementById("formHiddenHours").value = document.getElementById("hours").value;
                document.getElementById("formHiddenDemand").value = document.querySelector('input[name="demand"]:checked').value;
                document.getElementById("formHiddenTech").value = document.querySelector('input[name="tech"]:checked').value;
            });
        }

        function handleRadioClasses() {
            const demandRadios = document.getElementsByName("demand");
            if(demandRadios.length > 0) {
                document.getElementById("lblDemandStable").classList.toggle("radio-active-state", demandRadios[0].checked);
                document.getElementById("lblDemandFluct").classList.toggle("radio-active-state", demandRadios[1].checked);

                const techRadios = document.getElementsByName("tech");
                document.getElementById("lblTechFixed").classList.toggle("radio-active-state", techRadios[0].checked);
                document.getElementById("lblTechVfd").classList.toggle("radio-active-state", techRadios[1].checked);
            }
        }

        function calculate() {
            handleRadioClasses();

            const hp = parseFloat(document.getElementById("hp").value);
            const electricityRate = parseFloat(rate.value);
            const hours = parseFloat(document.getElementById("hours").value);

            const demand = document.querySelector('input[name="demand"]:checked').value;
            const tech = document.querySelector('input[name="tech"]:checked').value;

            const kw = hp * 0.746;
            let savingFactor = 0.05;

            if (demand === "fluctuating" && tech === "fixed") {
                savingFactor = 0.45;
            } else if (demand === "stable" && tech === "fixed") {
                savingFactor = 0.15;
            }

            const annualEnergy = kw * hours;
            const annualCost = annualEnergy * electricityRate;
            const annualSavings = annualCost * savingFactor;

            const formattedSavings = "₹ " + annualSavings.toLocaleString('en-IN', {
                maximumFractionDigits: 0
            });

            if ("@isUnlocked" === "True") {
                document.getElementById("savings").innerText = formattedSavings;
            }
        }

        calculate();
    });
</script>



