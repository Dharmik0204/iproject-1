<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    else
    {
        <meta name="description" content="AERODYNE EQUIPMENTS - High efficiency industrial rotary screw air compressors, reciprocating compressors, and downstream air treatment systems in Ahmedabad, Gujarat." />
    }

    @if (ViewData["MetaKeywords"] != null)
    {
        <meta name="keywords" content="@ViewData["MetaKeywords"]" />
    }

    <link class="canonical-node" rel="canonical" href="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" />

    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["MetaDescription"]" />
    <meta property="og:type" content="website" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --primary-blue: #004aad;
            --secondary-blue: #00337c;
            --light-bg: #000000;
            --footer-bg: #0b1224;
            --header-premium-bg: #0b1224;
        }

        body {
            font-family: 'Open Sans', sans-serif;
            background-color: var(--light-bg);
        }

        h1, h2, h3, h4, h5, h6, .nav-link, .footer-heading {
            font-family: 'Montserrat', sans-serif;
        }

        /* --- CLEAN LOGO NAVBAR --- */
        .top-bar {
            background-color: #060a14;
            color: #ffffff;
            padding: 10px 0;
            font-size: 0.82rem;
            font-weight: 500;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

            .top-bar a {
                color: rgba(255, 255, 255, 0.85);
                text-decoration: none;
                margin-left: 20px;
                transition: color 0.3s ease;
            }

                .top-bar a:hover {
                    color: #00d4ff;
                }

        .navbar {
            background: var(--header-premium-bg) !important;
            padding: 12px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            border-bottom: 2px solid var(--primary-blue);
        }

        .navbar-brand {
            padding: 0;
            margin-right: 0;
            background: transparent !important;
            border: none !important;
        }

            .navbar-brand img {
                height: 48px;
                width: auto;
                object-fit: contain;
                display: block;
            }

        .navbar-toggler {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            padding: 8px 12px;
            border-radius: 6px;
        }

        .navbar-toggler-icon {
            filter: invert(1) grayscale(1) brightness(2);
        }

        /* 🚀 BALANCED STABLE GRID HUB LINK MATRIX */
        .navbar-nav {
            display: flex;
            align-items: center;
            gap: 0px !important; /* Forces layout spacing to drop extra padding breaks */
            padding-left: 0;
            margin-bottom: 0;
            list-style: none;
        }

        .nav-link {
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.9) !important;
            padding: 10px 14px !important;
            letter-spacing: 0.5px;
            position: relative;
            white-space: nowrap !important; /* Forces industrial menu tags into single row lines */
            transition: all 0.3s ease;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                width: 0;
                height: 3px;
                bottom: 0;
                left: 14px;
                background-color: var(--primary-blue);
                transition: width 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            }

        @@media (min-width: 1200px) {
            .nav-link::after {
                bottom: -2px;
            }

            .nav-link:hover::after {
                width: calc(100% - 28px);
            }
        }

        .nav-link:hover {
            color: #00d4ff !important;
        }

        /* 🚀 ENFORCED SEARCH CONTROLS CONFIGURATION: FORCE WHITE TEXT ON TYPING */
        .header-search {
            position: relative;
            width: 220px;
        }

            .header-search input {
                border-radius: 4px;
                border: 1px solid rgba(255, 255, 255, 0.15);
                padding: 8px 15px 8px 40px;
                font-size: 0.85rem;
                background-color: rgba(255, 255, 255, 0.05) !important;
                color: #ffffff !important; /* Enforces type string value outputs clarity */
                width: 100%;
                transition: all 0.3s ease;
            }

                .header-search input::-webkit-input-placeholder {
                    color: rgba(255, 255, 255, 0.5) !important;
                }

                .header-search input::placeholder {
                    color: rgba(255, 255, 255, 0.5) !important;
                }

                .header-search input:focus {
                    border-color: #00d4ff !important;
                    background-color: rgba(255, 255, 255, 0.08) !important;
                    color: #ffffff !important;
                    box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.2) !important;
                    outline: none !important;
                }

            .header-search i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255, 255, 255, 0.5);
                z-index: 5;
            }

        /* --- FOOTER DESIGN --- */
        footer {
            background-color: var(--footer-bg);
            color: #94a3b8;
            padding: 80px 0 0 0;
            margin-top: 80px;
            border-top: 4px solid var(--primary-blue);
        }

        .footer-logo-container {
            background: transparent !important;
            padding: 0;
            border: none !important;
            margin-bottom: 20px;
        }

        .footer-logo {
            max-height: 50px;
            width: auto;
            object-fit: contain;
        }

        .footer-heading {
            color: #ffffff;
            font-weight: 600;
            font-size: 1rem;
            text-transform: uppercase;
            margin-bottom: 30px;
            position: relative;
        }

            .footer-heading::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -10px;
                width: 35px;
                height: 2px;
                background-color: var(--primary-blue);
            }

        .footer-link {
            color: #94a3b8;
            text-decoration: none;
            display: block;
            margin-bottom: 14px;
            transition: all 0.3s ease;
        }

            .footer-link:hover {
                color: #ffffff;
                transform: translateX(6px);
            }

        .btn-touch-corporate {
            background-color: var(--primary-blue) !important;
            color: #ffffff !important;
            border: 2px solid transparent !important;
            padding: 12px 28px;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            border-radius: 4px;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            display: inline-block;
            text-decoration: none;
        }

            .btn-touch-corporate:hover {
                background-color: transparent !important;
                color: #00d4ff !important;
                border-color: #00d4ff !important;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(0, 74, 173, 0.2);
            }

        .contact-item-box i {
            font-size: 1.2rem;
            color: var(--primary-blue);
            margin-right: 15px;
        }

        .social-circle-icons a {
            font-size: 1.1rem;
            color: #94a3b8;
            margin-right: 12px;
            width: 38px;
            height: 38px;
            background: rgba(255, 255, 255, 0.04);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

            .social-circle-icons a:hover {
                color: #ffffff;
                background-color: var(--primary-blue);
            }

        .bottom-copyright-bar {
            background-color: rgba(0, 0, 0, 0.2);
            padding: 25px 0;
            margin-top: 60px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* COMPREHENSIVE FLUID RESPONSIVE ENGINE FOR BREAKDOWNS MOBILE GRAPHICS */
        @@media (max-width: 1199.98px) {
            .navbar-collapse {
                background-color: #060a14;
                border-radius: 8px;
                margin-top: 15px;
                padding: 15px 20px !important;
                border: 1px solid rgba(255, 255, 255, 0.05);
            }

            .navbar-nav {
                align-items: flex-start !important;
                flex-direction: column !important;
                gap: 5px !important;
            }

            .nav-link {
                padding: 12px 0 !important;
                width: 100%;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }

                .nav-link::after {
                    display: none;
                }

            .header-search {
                width: 100%;
                margin-top: 15px;
                margin-left: 0;
            }
        }
    </style>
</head>
<body class="d-flex flex-column min-height-100">
    <header>
        <div class="top-bar d-none d-lg-block">
            <div class="container d-flex justify-content-between align-items-center">
                <div>
                    <span><i class="bi bi-clock-fill me-2 text-white-50"></i> Operations: Mon - Sat (10:00 AM - 6:00 PM)</span>
                </div>
                <div>
                    <a href="mailto:aerodyne.equipments@gmail.com"><i class="bi bi-envelope-fill me-2"></i> aerodyne.equipments@gmail.com</a>
                    <a href="tel:+916352386643"><i class="bi bi-telephone-fill me-2"></i> +91 63523-86643</a>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-xl navbar-dark sticky-top">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center w-100 flex-wrap flex-xl-nowrap">

                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/AERODYNELOGO.webp" alt="AERODYNE Compressors Industrial Branding Logotype" />
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav" style="flex-grow: 1;">
                        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center w-100 ms-xl-4">

                            <ul class="navbar-nav mx-auto mb-3 mb-xl-0">
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Product">Products</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="OEMSolution">OEM Solutions</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="AboutUs">About Us</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Calculation">Calculation</a></li>
                            </ul>

                            <div class="header-search">
                                <i class="bi bi-search"></i>
                                <input type="text" class="form-control" placeholder="Get Detailed Product Catelog">
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="flex-grow-1">
        <main role="main" class="pb-0">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 mb-4">
                    <div class="footer-logo-container">
                        <img src="~/images/AERODYNELOGO.webp" class="footer-logo" alt="AERODYNE Compressors White Base Vector" />
                    </div>
                    <p class="small pr-lg-4 mb-4 footer-span-text" style="font-size: 0.92rem;">
                        Innovating industrial air infrastructure with next-generation high-performance compressor arrays and certified system configurations.
                    </p>
                    <a asp-controller="Home" asp-action="ContactUs" class="btn btn-touch-corporate shadow-sm">Get Fleet Proposal</a>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 ps-lg-4">
                    <h5 class="footer-heading">Navigation</h5>
                    <div class="d-flex flex-column">
                        <a class="footer-link" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="footer-link" asp-controller="Home" asp-action="Product">Products</a>
                        <a class="footer-link" asp-controller="Home" asp-action="OEMSolution">OEM Solutions</a>
                        <a class="footer-link" asp-controller="Home" asp-action="AboutUs">About Us</a>
                        <a class="footer-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="footer-heading">Reach Us</h5>
                    <div class="contact-item-box d-flex mb-3">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span class="footer-span-text"><strong class="text-white">AERODYNE EQUIPMENTS</strong><br />Ahmedabad, Gujarat - 382430</span>
                    </div>
                    <div class="contact-item-box d-flex mb-3">
                        <i class="bi bi-telephone-fill"></i>
                        <span class="footer-span-text">Direct Engineering Line:<br><strong class="text-white">+91 63523-86643</strong></span>
                    </div>
                    <div class="contact-item-box d-flex">
                        <i class="bi bi-envelope-fill"></i>
                        <span class="footer-span-text">Support Desk:<br><strong class="text-white">aerodyne.equipments@@gmail.com</strong></span>
                    </div>
                </div>

                <div class="col-lg-2 mb-4 text-start text-lg-start d-flex flex-column align-items-start">
                    <h5 class="footer-heading">Follow Us</h5>
                    <div class="social-circle-icons mt-2">
                        <a href="https://facebook.com" title="Follow AERODYNE on Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="https://linkedin.com" title="Follow AERODYNE on LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>

            <div class="bottom-copyright-bar">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start mb-2 mb-md-0" style="color: #cbd5e1;">
                        &copy; 2026 <strong class="text-white">AERODYNE Equipments</strong>. All Engineering Rights Reserved.
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


